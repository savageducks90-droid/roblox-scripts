-- AUTO DETECT CHAKRA USERS
local list = Instance.new("TextLabel")
list.Size = UDim2.new(1,-10,0,80)
list.BackgroundTransparency = 1
list.TextColor3 = Color3.new(1,1,1)
list.Font = Enum.Font.SourceSans
list.TextWrapped = true
list.TextYAlignment = Enum.TextYAlignment.Top
list.Text = "Chakra Users:\nNone"
list.Parent = playersPage

local function updateChakra()

	local cooldowns = RS:FindFirstChild("Cooldowns")

	if not cooldowns then return end

	local users = {}

	for _,folder in ipairs(cooldowns:GetChildren()) do
		if folder:FindFirstChild("Chakra Sense") then
			table.insert(users,folder.Name)
		end
	end

	if #users == 0 then
		list.Text = "Chakra Users:\nNone"
	else
		list.Text = "Chakra Users:\n"..table.concat(users,"\n")
	end

end

if RS:FindFirstChild("Cooldowns") then

	for _,f in ipairs(RS.Cooldowns:GetChildren()) do
		f.ChildAdded:Connect(updateChakra)
		f.ChildRemoved:Connect(updateChakra)
	end

end

task.spawn(function()
	while true do
		updateChakra()
		task.wait(2)
	end
end)

