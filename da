-- safe script loader
local function getAndRun(url)
	local success, result = pcall(function()
		return game:HttpGet(url)
	end)

	if not success then
		warn("Download failed:",url)
		return
	end

	local func,err = loadstring(result)

	if not func then
		warn("Compile error:",err)
		return
	end

	local ran,runErr = pcall(func)

	if not ran then
		warn("Runtime error:",runErr)
	end
end

